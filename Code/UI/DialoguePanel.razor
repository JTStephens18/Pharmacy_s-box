@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent

<root>
    @if ( DialogueManager.Instance?.IsActive == true )
    {
        var dm = DialogueManager.Instance;
        <div class="dialogue-overlay">
            <div class="dialogue-box">
                <div class="dialogue-speaker">@dm.SpeakerName</div>
                <div class="dialogue-body">@dm.BodyText</div>

                <div class="dialogue-responses">
                    @if ( dm.IsTerminal )
                    {
                        <button class="response-button" onclick=@(() => dm.Continue())>
                            @dm.CloseButtonText
                        </button>
                    }
                    else
                    {
                        for ( int i = 0; i < dm.CurrentResponses.Count; i++ )
                        {
                            var idx = i;
                            <button class="response-button" onclick=@(() => dm.SelectResponse(idx))>
                                @dm.CurrentResponses[idx].Text
                            </button>
                        }
                    }
                </div>
            </div>
        </div>
    }
</root>

@code {
    protected override int BuildHash() =>
        System.HashCode.Combine(
            DialogueManager.Instance?.IsActive,
            DialogueManager.Instance?.BodyText,
            DialogueManager.Instance?.SpeakerName,
            DialogueManager.Instance?.CurrentResponses?.Count
        );
}
